---
// src/components/asset-frame.astro
// Import komponen Icon native dari astro-icon
import { Icon } from "astro-icon/components";

interface Props {
  label: string;
  ratio?: string;
  tone?: "light" | "dark";
}

const { 
  label, 
  ratio = "aspect-[4/3]", 
  tone = "light" 
} = Astro.props;
---

<div
  data-asset-placeholder
  class={`flex ${ratio} items-center justify-center rounded-lg border border-dashed border-gray-200 ${
    tone === "dark" ? "bg-[#0F172A] text-white" : "bg-white"
  }`}
>
  <div class="flex flex-col items-center gap-2 opacity-60">
    <Icon name="lucide:image" class="h-8 w-8" />
    <span class="font-mono text-xs uppercase tracking-widest">{label}</span>
  </div>
</div>