---
// src/components/download-card.astro
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  format: string;
  size: string;
  description?: string;
  url: string; 
}

const { title, format, size, description, url } = Astro.props;
---

<div class="group flex items-start justify-between gap-4 rounded-lg border border-gray-100 bg-white p-5 shadow-xs transition-all hover:border-gray-200 hover:shadow-sm relative">
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2.5 flex-wrap">
      <span class="inline-flex items-center rounded bg-gray-50 px-2 py-0.5 font-mono text-[10px] font-bold tracking-wider text-gray-500 uppercase border border-gray-100">
        {format}
      </span>
      <span class="font-mono text-xs text-gray-400">{size}</span>
    </div>
    
    <h3 class="mt-2.5 font-semibold text-[#0F172A] text-sm group-hover:text-[#025A8F] transition-colors truncate">
      {title}
    </h3>
    
    {description && (
      <p class="mt-1 text-xs text-gray-400 leading-relaxed">{description}</p>
    )}
  </div>

  <a 
    href={url}
    target="_blank" 
    rel="noopener noreferrer"
    class="p-2 rounded-md bg-gray-50 text-gray-400 group-hover:bg-[#025A8F] group-hover:text-white transition-all focus:outline-none flex items-center justify-center z-10 shrink-0"
    aria-label={`Unduh berkas ${title}`}
  >
    <Icon name="lucide:download" class="h-4 w-4" />
    
    <span class="sr-only">Unduh berkas {title}</span>
  </a>
</div>