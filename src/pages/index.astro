---
// src/pages/index.astro
import '/src/styles/global.css'; // <-- Tambahkan tanda / di depan src

const SECTIONS = [
  { number: "01", title: "Pusat Unduhan", to: "/unduhan", blurb: "Akses berkas master logo berkualias tinggi, templat dokumen, dan aset digital resmi." },
  { number: "02", title: "Segel Akademik", to: "/akademik", blurb: "Aturan penggunaan segel universitas untuk ijazah, sertifikat, dan dokumen formal universitas." },
  { number: "03", title: "Signature Logo", to: "/signature-logo", blurb: "Panduan konfigurasi logo utama, rasio area aman, dan kombinasi teks identitas." },
  { number: "04", title: "Lambang Fakultas", to: "/fakultas", blurb: "Standarisasi lambang dan identitas visual turunan untuk setiap fakultas di lingkungan UIN." },
  { number: "05", title: "Tipografi Logo", to: "/tipografi-logo", blurb: "Pedoman rincian anatomi huruf pembentuk teks logotype resmi universitas." },
  { number: "06", title: "Warna", to: "/warna", blurb: "Palet warna resmi (hijau, biru UIN, emas) beserta kode HEX, CMYK, dan aturan kombinasinya." },
  { number: "07", title: "Tipografi", to: "/tipografi", blurb: "Sistem hierarki font resmi yang disetujui untuk media cetak maupun publikasi digital." },
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Guideline — UIN Syarif Hidayatullah Jakarta</title>
    <meta name="description" content="Sistem identitas visual UIN Jakarta: logo, lambang fakultas, warna, tipografi, dan unduhan." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#FBFBFB] text-[#1E293B] antialiased min-h-screen flex flex-col">
    
    <header class="sticky top-0 z-40 w-full bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-5 md:px-12 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <button 
          id="menu-toggle" 
          class="md:hidden p-1 text-gray-600 hover:text-[#025A8F] transition-colors focus:outline-none"
          aria-label="Toggle Sidebar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        
        <a href="/" class="font-bold text-xl tracking-tight text-[#0F172A]">
          UIN Jakarta <span class="text-xs font-semibold tracking-widest text-gray-400 ml-1 uppercase">Brand</span>
        </a>
      </div>
      
      <nav class="flex items-center gap-6 text-sm font-medium text-gray-600">
        <a href="/" class="text-[#0F172A] font-semibold">Beranda</a>
        <a href="#" class="hover:text-[#025A8F] transition-colors">Pusat Unduhan</a>
      </nav>
    </header>

    <div class="flex-1 flex flex-col md:flex-row relative">
      
      <div 
        id="sidebar-backdrop" 
        class="fixed inset-0 bg-black/20 z-20 hidden opacity-0 transition-opacity duration-300 pointer-events-none md:hidden"
      ></div>

      <aside 
        id="sidebar" 
        class="fixed inset-y-0 left-0 z-30 w-64 bg-[#FBFBFB] border-r border-gray-100 p-6 pt-24 md:pt-12 transform -translate-x-full transition-transform duration-300 md:sticky md:top-[73px] md:h-[calc(100vh-73px)] md:translate-x-0 md:w-72 shrink-0 overflow-y-auto"
      >
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-gray-400 mb-6 px-2">Bagian</p>
        <nav class="space-y-1">
          {SECTIONS.map((s) => (
            <a href={s.to} class="flex items-center gap-4 px-2 py-2.5 rounded-md text-sm font-medium text-gray-600 hover:text-[#025A8F] hover:bg-gray-50 transition-all">
              <span class="font-mono text-xs text-gray-400">{s.number}</span>
              <span>{s.title}</span>
            </a>
          ))}
        </nav>
      </aside>

      <main class="flex-1 px-6 py-12 md:p-16 max-w-4xl">
        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-gray-400">
            Pedoman Identitas Visual · 2026
          </p>
          <h1 class="mt-6 font-serif text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.1] tracking-tight text-[#0F172A]">
            Satu identitas, <span class="text-[#025A8F]">satu suara</span> untuk UIN Jakarta.
          </h1>
          <p class="mt-8 max-w-2xl text-base sm:text-lg text-gray-500 leading-relaxed">
            Pedoman ini mengatur penggunaan lambang, warna, dan tipografi resmi
            UIN Syarif Hidayatullah Jakarta — dirancang agar setiap penerapan
            tetap konsisten, akademik, dan bermartabat.
          </p>
          
          <div class="mt-10 flex flex-wrap gap-3">
            <a href="#" class="inline-flex items-center gap-2 rounded-md bg-[#0A1D37] px-5 py-3 text-sm font-medium text-white hover:bg-[#112D52] transition-colors shadow-sm">
              Pusat Unduhan
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a href="/akademik" class="inline-flex items-center gap-2 rounded-md border border-gray-200 bg-white px-5 py-3 text-sm font-medium text-[#1E293B] hover:bg-gray-50 hover:border-gray-300 transition-colors">
              Mulai dari logo
            </a>
          </div>
        </section>
      </main>

    </div>

    <script>
      // Menggunakan Type Assertion 'as HTMLElement' untuk menjamin elemen ada pada runtime
      const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
      const sidebar = document.getElementById('sidebar') as HTMLElement | null;
      const backdrop = document.getElementById('sidebar-backdrop') as HTMLElement | null;

      function toggleSidebar(): void {
        if (!sidebar || !backdrop) return;

        const isHidden = sidebar.classList.contains('-translate-x-full');

        if (isHidden) {
          // Buka Sidebar
          sidebar.classList.remove('-translate-x-full');
          backdrop.classList.remove('hidden', 'pointer-events-none');
          backdrop.classList.add('opacity-100');
        } else {
          // Tutup Sidebar
          sidebar.classList.add('-translate-x-full');
          backdrop.classList.remove('opacity-100');
          backdrop.classList.add('hidden', 'pointer-events-none');
        }
      }

      // Menambahkan Event Listener dengan aman menggunakan optional chaining (?.)
      menuToggle?.addEventListener('click', toggleSidebar);
      backdrop?.addEventListener('click', toggleSidebar);
    </script>
  </body>
</html>

<style is:global>
  body { font-family: 'Plus Jakarta Sans', sans-serif; }
  .font-serif { font-family: 'Playfair Display', serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }
</style>